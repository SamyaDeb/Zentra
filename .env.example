# ==========================================
# ZENTRA - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env.local and fill in your values

# ==========================================
# STELLAR / SOROBAN CONFIGURATION
# ==========================================

# TrustCircles Contract ID (deployed on Stellar Testnet)
# Get this after running: stellar contract deploy
NEXT_PUBLIC_CONTRACT_ID=your_contract_id_here

# Native XLM Token SAC Address (Stellar Asset Contract for XLM)
# This is the wrapper contract for native XLM on Soroban
NEXT_PUBLIC_NATIVE_TOKEN_ID=your_xlm_sac_address_here

# ==========================================
# NETWORK CONFIGURATION
# ==========================================
# The app defaults to Stellar Testnet. These are set in config/stellarConfig.ts
# For mainnet deployment, update CURRENT_NETWORK in stellarConfig.ts

# Horizon API (default: https://horizon-testnet.stellar.org)
# Soroban RPC (default: https://soroban-testnet.stellar.org)

# ==========================================
# ADMIN CONFIGURATION
# ==========================================
# Admin address is set in config/stellarConfig.ts
# Default: GBDD6IDWYK5XM77GYSPKW7BC2KY3D4DPNP3MFQVHZJ3BCWMHB3T7NDWT

# ==========================================
# DEPLOYMENT (for stellar CLI)
# ==========================================
# When deploying, ensure you have:
# 1. Stellar CLI installed: cargo install stellar-cli
# 2. Funded testnet account (use Friendbot)
# 3. Rust toolchain with wasm32-unknown-unknown target
